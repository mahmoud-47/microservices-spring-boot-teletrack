# =============================================================================
# TeleTrack360 — Environment Variables
# Copy this to .env and fill in all values before running docker compose
# NEVER commit .env to git
# Now cook !!
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- MongoDB ---
MONGO_USERNAME=admin
MONGO_PASSWORD=admin

# --- Redis ---
REDIS_PASSWORD=redis_password

# --- Kafka ---
# Set to your VPS/host IP if you need external Kafka access; keep localhost otherwise
KAFKA_EXTERNAL_HOST=localhost

# --- JWT ---
JWT_SECRET=***

# --- Gateway ---
GATEWAY_SERVICE_KEY=***

# --- Incident Service ---
INCIDENT_SERVICE_API_KEY=***

# --- Google OAuth2 ---
GOOGLE_CLIENT_ID=***
GOOGLE_CLIENT_SECRET=***

# --- Frontend / Backend URLs ---
FRONT_URL=http://localhost:3000
BACK_URL=http://localhost:8080

# --- Mail (SMTP) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=***
MAIL_PASSWORD=***

# --- OpenAI ---
OPENAI_API_KEY=***
FLASK_ENV=production
FLASK_DEBUG=True

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3001

# --- Hikari CP (Database Connection Pooling) ---
# Goal: Maintain enough connections for speed without exhausting DB resources.
HIKARI_MAX_POOL_SIZE=10
HIKARI_MIN_IDLE=5
HIKARI_IDLE_TIMEOUT=600000          # 10 minutes in ms
HIKARI_CONNECTION_TIMEOUT=30000     # 30 seconds in ms
HIKARI_MAX_LIFETIME=1800000         # 30 minutes in ms
HIKARI_LEAK_DETECTION_THRESHOLD=2000 # 2 seconds (0 to disable)

# --- Tomcat (Web Server Threading) ---
# Goal: Handle concurrent HTTP requests.
TOMCAT_MAX_THREADS=200
TOMCAT_MIN_SPARE_THREADS=10
TOMCAT_ACCEPT_COUNT=100             # Queue size when all threads are busy
TOMCAT_MAX_CONNECTIONS=8192

# --- Executor (Async Task Processing) ---
# Goal: Manage background tasks (especially for notification/reporting).
EXECUTOR_CORE_SIZE=5
EXECUTOR_MAX_SIZE=20
EXECUTOR_QUEUE_CAPACITY=500
EXECUTOR_KEEP_ALIVE=60s             # Spring Duration format (e.g. 60s, 2m)

# --- Circuit Breaker (Resilience4j / Feign) ---
# Goal: Stop calling a failing service to allow it to recover.
FEIGN_CB_ENABLED=true
CB_SLIDING_WINDOW_SIZE=10           # Look at last 10 calls
CB_MIN_CALLS=5                      # Min calls before calculating error rate
CB_FAILURE_RATE_THRESHOLD=50        # Open circuit if 50% fail
CB_WAIT_DURATION_OPEN_STATE=60s     # Stay open for 60s before trying again (Spring Duration format)
CB_HALF_OPEN_PERMITTED_CALLS=3      # Test 3 calls in half-open state
CB_SLOW_CALL_DURATION_THRESHOLD=2s  # Calls > 2s are "slow" (Spring Duration format)
CB_SLOW_CALL_RATE_THRESHOLD=50      # Open circuit if 50% are slow

ES_JAVA_OPTS=-Xms512m -Xmx512m