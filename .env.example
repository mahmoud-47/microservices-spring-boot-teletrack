# =============================================================================
# TeleTrack360 — Environment Variables
# Copy this to .env and fill in all values before running docker compose
# NEVER commit .env to git
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=***
POSTGRES_PASSWORD=***

# --- MongoDB ---
MONGO_USERNAME=***
MONGO_PASSWORD=***

# --- Redis ---
REDIS_PASSWORD=***

# --- Kafka ---
# Set to your VPS/host IP if you need external Kafka access; keep localhost otherwise
KAFKA_EXTERNAL_HOST=localhost

# --- JWT ---
JWT_SECRET=***

# --- Gateway ---
GATEWAY_SERVICE_KEY=***

# --- Incident Service ---
INCIDENT_SERVICE_API_KEY=***

# --- Google OAuth2 ---
GOOGLE_CLIENT_ID=***
GOOGLE_CLIENT_SECRET=***

# --- Frontend / Backend URLs ---
FRONT_URL=http://localhost:3000
BACK_URL=http://localhost:8080

# --- Mail (SMTP) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=***@gmail.com
MAIL_PASSWORD=**** **** **** ****

# --- OpenAI ---
OPENAI_API_KEY=***
FLASK_ENV=production
FLASK_DEBUG=True

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3001
